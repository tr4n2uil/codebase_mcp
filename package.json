{
  "name": "@tr4n2uil/codebase-mcp",
  "version": "1.0.7",
  "description": "Local vector index + MCP server for codebase semantic search (TypeScript, Xenova transformers, LanceDB)",
  "type": "module",
  "main": "dist/main.js",
  "bin": {
    "codebase-mcp": "dist/main.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "prestart": "npm run build",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm run typecheck",
    "ps": "ps auxww | grep node | grep codebase_mcp",
    "publish": "npm run build && npm run typecheck && npm version patch && npm publish"
  },
  "keywords": [
    "mcp",
    "vector",
    "embeddings",
    "codebase"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tr4n2uil/codebase_mcp.git"
  },
  "homepage": "https://github.com/tr4n2uil/codebase_mcp#readme",
  "bugs": {
    "url": "https://github.com/tr4n2uil/codebase_mcp/issues"
  },
  "dependencies": {
    "@lancedb/lancedb": "^0.27.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@xenova/transformers": "^2.17.2",
    "chokidar": "^5.0.0",
    "ignore": "^7.0.5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=18"
  }
}
